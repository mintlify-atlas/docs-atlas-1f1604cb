  "keyFeatures": [
    "Type-safe HTTP server and client built on ZIO",
    "Imperative and declarative endpoint definitions",
    "Built-in WebSocket support for real-time applications",
    "Middleware and handler aspects for cross-cutting concerns",
    "OpenAPI documentation generation and endpoint generation from OpenAPI specs",
    "Streaming request and response bodies with ZIO Streams",
    "SSL/TLS support with multiple authentication schemes",
    "HTML templating DSL for server-side rendering",
    "Testing utilities without requiring a live server",
    "Integration with ZIO Schema for JSON, Protobuf, Avro, and Thrift codecs"
  ],
  "publicApiSurface": [
    "Routes - Collection of HTTP routes",
    "Route - Single route with pattern and handler",
    "Handler - Function from Request to Response",
    "Server - HTTP server for serving routes",
    "Client - HTTP client for making requests",
    "Request - HTTP request with method, path, headers, and body",
    "Response - HTTP response with status, headers, and body",
    "Middleware - Cross-cutting concerns for routes",
    "HandlerAspect - Aspects for transforming handlers",
    "Endpoint - Declarative API endpoint definitions",
    "HttpCodec - Type-safe HTTP codecs for request/response",
    "WebSocketApp - WebSocket application handler",
    "Body - Request/response body with streaming support",
    "Headers - HTTP headers collection",
    "Status - HTTP status codes",
    "Method - HTTP methods (GET, POST, etc.)",
    "Path - URL path with type-safe extraction",
    "QueryParams - URL query parameters",
    "Cookie - HTTP cookies",
    "Form - Multipart form data",
    "SSLConfig - SSL/TLS configuration",
    "Template - HTML templating DSL"
  ]
}
